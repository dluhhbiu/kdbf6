{
  "name": "bf6-stats",
  "version": "1.0.0",
  "description": "**[Live Demo](https://dluhhbiu.github.io/kdbf6/)**",
  "main": "electron/main.js",
  "scripts": {
    "start": "electron .",
    "build": "electron-builder --win portable",
    "pack": "electron-builder --win --dir"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/dluhhbiu/kdbf6.git"
  },
  "keywords": [],
  "author": "",
  "license": "ISC",
  "bugs": {
    "url": "https://github.com/dluhhbiu/kdbf6/issues"
  },
  "homepage": "https://github.com/dluhhbiu/kdbf6#readme",
  "devDependencies": {
    "electron": "^35.0.0",
    "electron-builder": "^26.0.0"
  },
  "build": {
    "appId": "com.bf6stats.widget",
    "productName": "BF6 Stats",
    "files": [
      "index.html",
      "favicon.png",
      "electron/**/*"
    ],
    "win": {
      "target": "portable",
      "icon": "icon.png"
    },
    "portable": {
      "artifactName": "BF6-Stats-Portable.exe"
    }
  }
}
